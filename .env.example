# Postgres (solo servidor): RIMEC ventas + Stock retail (retail_multitienda_staging, v_ventas_pivot).
# En Vercel: Environment Variables → DATABASE_URL (no uses NEXT_PUBLIC_ para credenciales).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# NEXT_PUBLIC_SUPABASE_URL — URL del proyecto (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co

# Anon key (Settings → API) — solo lecturas que permita RLS; nunca service_role en el front.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opción A: ruta relativa dentro del bucket público "productos" (como en v_stock_web)
# Ejemplo: carpeta/archivo.jpg
NEXT_PUBLIC_SAMPLE_PRODUCT_PATH=

# Opción B: URL completa de una imagen pública (sobreescribe la opción A)
# NEXT_PUBLIC_DEMO_IMAGE_URL=
